class Shape {
    void area() {
        System.out.println("Area of shape...");
    }
}

class Circle extends Shape {
    void area() {
        System.out.println("Area of Circle = πr²");
    }
}

class Square extends Shape {
    void area() {
        System.out.println("Area of Square = side × side");
    }
}

public class Main {
    public static void main(String[] args) {
        Shape s1 = new Circle();
        Shape s2 = new Square();

        s1.area();  
        s2.area(); 
    }
}
