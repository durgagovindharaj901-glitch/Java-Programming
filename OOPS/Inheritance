class Vehicle {
    void start() {
        System.out.println("Vehicle starts...");
    }
}

class Car extends Vehicle {
    void honk() {
        System.out.println("Car honks!");
    }
}

public class Main {
    public static void main(String[] args) {
        Car c = new Car();
        c.start(); 
        c.honk();  
    }
}
